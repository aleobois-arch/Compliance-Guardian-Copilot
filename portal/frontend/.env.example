# ============================================================
# Frontend Environment Variables - copy to .env.local and fill
# ============================================================

# Azure AD / Entra ID App Registration
VITE_AZURE_CLIENT_ID=your-app-registration-client-id
VITE_AZURE_TENANT_ID=your-azure-tenant-id

# The API scope exposed by your backend App Registration
# e.g. api://<client-id>/Compliance.Read
VITE_API_SCOPE=api://your-backend-client-id/Compliance.ReadWrite
