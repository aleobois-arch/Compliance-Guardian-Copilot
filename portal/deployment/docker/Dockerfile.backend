FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY portal/backend/src/Portal.Api/ ./Portal.Api/
COPY portal/backend/src/Portal.Domain/ ./Portal.Domain/
COPY portal/backend/src/Portal.Infrastructure/ ./Portal.Infrastructure/

WORKDIR /src/Portal.Api
RUN dotnet restore
RUN dotnet publish -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app ./

ENV ASPNETCORE_URLS=http://+:5000
EXPOSE 5000

ENTRYPOINT ["dotnet", "Portal.Api.dll"]
